# =============================================================================
# Asset Bridge 3D - Variables d'environnement
# Copiez ce fichier en .env.local pour le développement local
# Dans Coolify, configurez ces variables directement dans l'interface
# =============================================================================

# Clé secrète d'authentification pour l'upload
# Les designers saisissent cette valeur dans le champ mot de passe de l'UI
UPLOAD_SECRET_KEY=change-me-strong-secret-key

# Clé SSH privée complète pour git push vers GitHub
# Collez le contenu complet de votre id_rsa (avec les en-têtes -----BEGIN/END-----)
# Dans Coolify : copiez le contenu multiligne dans la variable
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
...votre clé privée ici...
-----END OPENSSH PRIVATE KEY-----"

# URL SSH du dépôt GitHub cible
GIT_REPO_URL=git@github.com:votre-org/votre-repo.git

# Branche cible pour le git push
GIT_BRANCH=main
